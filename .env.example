# PostgreSQL connection string (used by Prisma ORM)
DATABASE_URL=postgresql://app:app@localhost:5432/app_dev

# Server listening port
PORT=3000

# Runtime environment: development | production
NODE_ENV=development

# Comma-separated allowed CORS origins (required in production)
# CORS_ORIGINS=https://yourdomain.com

# PostgreSQL credentials (used by docker-compose)
# Override these in .env for custom local database config
# POSTGRES_USER=app
# POSTGRES_PASSWORD=app
# POSTGRES_DB=app_dev
